---
import Breadcrumbs from "./Breadcrumbs.astro";

const postFiles = import.meta.glob("../pages/post/*.md", { eager: true });
const posts = Object.values(postFiles)
  .filter((post) => post?.frontmatter)
  .sort((a, b) => new Date(b.frontmatter.publishDate) - new Date(a.frontmatter.publishDate));
---

<section class="blog-section" aria-labelledby="blog-heading">
  <h2 id="blog-heading" class="blog-title">Blog</h2>
  <Breadcrumbs />
  <div class="container-card">
    {
      posts.map((post) => {
        const { frontmatter, url } = post;
        const { title, description, readingTime } = frontmatter;

        return (
          <article class="blog-card">
            <a href={url} aria-label={`Leer artículo: ${title}`}>
              <div class="card-content">
                  <p class="reading-time">
                    <time datetime={`PT${readingTime}M`}>
                      {readingTime} min read
                    </time>
                  </p>
                <div class="text-container">
                  <h3 class="card-title">{title}</h3>
                  <p class="card-text">{description}</p>
                </div>
              </div>
            </a>
          </article>
        );
      })
    }
  </div>
</section>

<style>
  :root {
    --shadow-card: 0 6px 18px rgba(2,6,23,0.08), 0 2px 6px rgba(2,6,23,0.04);
    --shadow-card-hover: 0 18px 36px rgba(2,6,23,0.12), 0 8px 16px rgba(2,6,23,0.06);
  }

  /* --- Estructura General --- */
  .blog-section {
    padding: 1.2rem 1.3rem;
    width: var(
      --width-container
    ); /* Asegúrate de que esta variable exista en global */
    max-width: 1200px;
    margin: 8rem auto 4rem auto;
  }

  .blog-title {
    font-size: 2.5rem;
    font-family: var(--font-title);
    font-weight: 300;
    text-align: center;
    color: var(--color-text);
    margin-bottom: 3rem;
  }

  .container-card {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2.3rem;
  }

  /* --- Tarjeta --- */
  .blog-card {
    box-shadow: var(--shadow-card);
    border: 1px solid var(--color-bgsecondary);
    border-radius: 1.5rem;
    overflow: hidden;
    transition:
      border-color 0.3s ease,
      box-shadow 0.3s ease,
      transform 0.3s ease;
    height: auto;

  }

  .blog-card a {
    text-decoration: none;
    color: var(--color-text);
    display: block;
    cursor: pointer;
    height: 100%;
  }

  .card-content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    height: 100%;
    min-height: 220px;
    padding: 2rem;
    gap: 1rem;
  }

  .reading-time {
    font-size: 0.8rem;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--color-primary);
    font-weight: 600;
    flex-shrink: 0;
  }

  /* --- Texto --- */
  .text-container {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    text-align: left;
    width: 100%;
  }

  .card-title {
    font-size: clamp(1.4rem, 2vw, 1.8rem);
    font-family: var(--font-title);
    font-weight: 600;
    line-height: 1.3;
    transition: color 0.3s ease;
    margin-bottom: 0.8rem;
  }

  .blog-card:hover .card-title {
    color: var(--color-primary);
  }

  .blog-card a:focus-visible {
    outline: 3px solid var(--color-primary);
    outline-offset: 4px;
  }

  .blog-card:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-card-hover);
  }

  .card-text {
    font-size: 1.2rem;
    line-height: 1.6;
    opacity: 0.85;

    /* Truncar texto a 3 líneas */
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* --- RESPONSIVE / MEDIA QUERIES --- */

  @media (max-width: 800px) {
    .blog-section {
      margin: 4rem auto;
    }

    .card-content {
      min-height: 160px;
      padding: 1.5rem;
    }
  }

  /* Preferencias de movimiento reducido */
  @media (prefers-reduced-motion: reduce) {
    .blog-card {
      transition: none;
    }
    .blog-card:hover {
      transform: none;
    }
  }
</style>
