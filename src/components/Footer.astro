---

<footer class="footer">
  <div class="footer-glow"></div>
  <div class="footer-content">
    <div class="footer-brand">
      <a href="/" class="footer-logo">
        <span class="logo-text">MP88</span>
      </a>
      <p class="footer-tagline">
        Creando experiencias digitales con pasión y precisión.
      </p>
    </div>

    <div class="footer-links">
      <div class="link-group">
        <h4>Navegación</h4>
        <ul>
          <li><a href="/">Inicio</a></li>
          <li><a href="/about/">Sobre mí</a></li>
          <li><a href="/blog/">Blog</a></li>
          <li><a href="/projects/">Proyectos</a></li>
        </ul>
      </div>
      <div class="link-group">
        <h4>Social</h4>
        <ul>
          <li>
            <a href="https://github.com/dmipaguirre" target="_blank" rel="noopener">
              <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="currentColor"
                ><path
                  d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"
                ></path></svg
              >
              GitHub
            </a>
          </li>
          <li>
            <a href="https://www.linkedin.com/in/dmpaeza/" target="_blank" rel="noopener">
              <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="currentColor"
                ><path
                  d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                ></path></svg
              >
              LinkedIn
            </a>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="footer-divider"></div>
    <div class="footer-bottom-content">
      <p class="copyright">
        &copy; <span id="current-year"></span> MP88.
      </p>
      <p class="made-with">
        Hecho con
        <span class="heart-icon">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path
              d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"
            ></path>
          </svg>
        </span>
        y café
      </p>
    </div>
  </div>
</footer>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    const yearElement = document.getElementById("current-year");
    if (yearElement) {
      yearElement.textContent = new Date().getFullYear().toString();
    }
  });
</script>

<style>
  .footer {
    overflow: hidden;
    max-width: 1200px;
    margin: 4rem auto;
  }

  .footer-glow {
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      var(--color-primary),
      transparent
    );
    margin-bottom: 2rem;
  }

  .footer-content {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    max-width: 1200px;
    margin: 0 auto;
    padding: 5rem 1.3rem 3rem;
    gap: 4rem;
  }

  .footer-brand {
    flex: 1;
    max-width: 280px;
  }

  .footer-logo {
    display: inline-block;
    text-decoration: none;
    margin-bottom: 1.5rem;
  }

  .footer-logo .logo-text {
    font-family: var(--font-title);
    font-size: 2rem;
    background-color: var(--color-primary);
    color: var(--color-bg);
    padding: 0.35rem 0.75rem;
    border-radius: 0.5rem;
    transform: rotate(-3deg);
    display: inline-block;
    line-height: 1;
  }

  .footer-tagline {
    font-family: var(--font-text);
    color: var(--color-text);
    opacity: 0.65;
    font-size: 1rem;
    line-height: 1.7;
  }

  .footer-links {
    display: flex;
    gap: 5rem;
  }

  .link-group h4 {
    font-family: var(--font-title);
    font-size: 0.9rem;
    color: var(--color-text);
    margin-bottom: 1.5rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    position: relative;
    display: inline-block;
  }

  .link-group ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .link-group ul li {
    margin-bottom: 0.9rem;
  }

  .link-group ul li a {
    font-family: var(--font-text);
    color: var(--color-text);
    text-decoration: none;
    opacity: 0.6;
    font-size: 1rem;
    transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
  }

  .link-group ul li a svg {
    opacity: 0.7;
    transition: all 0.3s ease;
  }

  .link-group ul li a:hover {
    opacity: 1;
    color: var(--color-primary);
    transform: translateX(6px);
  }

  .link-group ul li a:hover svg {
    opacity: 1;
    color: var(--color-primary);
  }

  .footer-bottom {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.3rem 0;
  }

  .footer-bottom-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .copyright {
    font-family: var(--font-text);
    color: var(--color-text);
    opacity: 0.5;
    font-size: 0.9rem;
  }

  .made-with {
    font-family: var(--font-text);
    color: var(--color-text);
    opacity: 0.5;
    font-size: 0.9rem;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .heart-icon {
    display: inline-flex;
    color: var(--color-primary);
    animation: heartbeat 1.5s ease-in-out infinite;
  }

  @keyframes heartbeat {
    0%,
    100% {
      transform: scale(1);
    }
    15% {
      transform: scale(1.15);
    }
    30% {
      transform: scale(1);
    }
    45% {
      transform: scale(1.1);
    }
    60% {
      transform: scale(1);
    }
  }

  @media (width < 900px) {
    .footer-content {
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 3rem;
      padding-top: 4rem;
    }

    .footer-brand {
      max-width: none;
    }

    .footer-links {
      gap: 4rem;
    }

    .link-group h4::after {
      left: 50%;
      transform: translateX(-50%);
    }
  }

  @media (width < 600px) {
    .footer-content {
      padding: 3rem 1.3rem 2rem;
    }

    .footer-links {
      flex-direction: column;
      gap: 2.5rem;
    }

    .link-group {
      text-align: center;
    }

    .link-group ul li a:hover {
      transform: none;
    }

    .footer-bottom-content {
      flex-direction: column;
      gap: 0.8rem;
      text-align: center;
    }
  }
</style>
